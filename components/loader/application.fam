App(
    appid="loader",
    name="LoaderSrv",
    apptype=FlipperAppType.SERVICE,
    entry_point="loader_srv",
    cdefines=["SRV_LOADER"],
    requires=[
        "gui",
        "dialogs",
        "storage",
    ],
    stack_size=4 * 1024,
    order=60,
    sdk_headers=["loader.h"],
)

App(
    appid="loader_start",
    apptype=FlipperAppType.STARTUP,
    entry_point="loader_on_system_start",
    requires=["loader"],
    order=20,
)
