App(
    appid="storage",
    name="StorageSrv",
    apptype=FlipperAppType.SERVICE,
    entry_point="storage_srv",
    cdefines=["SRV_STORAGE"],
    stack_size=4 * 1024,
    order=40,
    sdk_headers=["storage.h"],
)

App(
    appid="storage_start",
    apptype=FlipperAppType.STARTUP,
    entry_point="storage_on_system_start",
    requires=["storage"],
    order=10,
)
