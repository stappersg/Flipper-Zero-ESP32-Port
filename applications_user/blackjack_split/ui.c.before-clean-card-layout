#include <math.h>
#include <notification/notification_messages.h>

#include "ui.h"

#define LINE_HEIGHT 16
#define ITEM_PADDING 4

const char MoneyMul[4] = {
    'K', 'B', 'T', 'S'
};

static void draw_label(Canvas* canvas, int16_t x, int16_t y, const char* text) {
    canvas_set_color(canvas, ColorBlack);
    canvas_draw_rbox(canvas, x, y, 36, 10, 2);
    canvas_set_color(canvas, ColorWhite);
    canvas_set_font(canvas, FontSecondary);
    canvas_draw_str_aligned(canvas, x + 18, y + 5, AlignCenter, AlignCenter, text);
    canvas_set_color(canvas, ColorBlack);
}

static void draw_compact_cards(
    Canvas* canvas,
    const Card* cards,
    uint8_t count,
    int16_t x,
    int16_t y) {

    uint8_t visible = count > 5 ? 5 : count;

    for(uint8_t i = 0; i < visible; i++) {
        draw_card_at(
            x + (int16_t)i * 14,
            y,
            cards[i].pip,
            cards[i].character,
            canvas);
    }
}

void draw_player_scene(Canvas* const canvas, const GameState* game_state) {
    canvas_set_color(canvas, ColorBlack);

    draw_label(canvas, 4, 3, "DEALER");

    if(game_state->dealer_card_count > 0) {
        draw_card_back_at(47, 3, canvas);
    }

    if(game_state->dealer_card_count > 1) {
        draw_card_at(
            65,
            3,
            game_state->dealer_cards[1].pip,
            game_state->dealer_cards[1].character,
            canvas);
    }

    canvas_draw_line(canvas, 3, 29, 124, 29);

    draw_label(canvas, 4, 33, "YOU");

    if(game_state->player_card_count > 0) {
        draw_compact_cards(
            canvas,
            game_state->player_cards,
            game_state->player_card_count,
            47,
            32);
    }

    char score[18];
    snprintf(
        score,
        sizeof(score),
        "Score %u",
        hand_count(game_state->player_cards, game_state->player_card_count));

    canvas_set_font(canvas, FontSecondary);
    canvas_draw_str_aligned(canvas, 122, 42, AlignRight, AlignCenter, score);
}

void draw_dealer_scene(Canvas* const canvas, const GameState* game_state) {
    canvas_set_color(canvas, ColorBlack);

    draw_label(canvas, 4, 3, "DEALER");

    if(game_state->dealer_card_count > 0) {
        draw_compact_cards(
            canvas,
            game_state->dealer_cards,
            game_state->dealer_card_count,
            47,
            3);
    }

    char dealer_score[18];
    snprintf(
        dealer_score,
        sizeof(dealer_score),
        "Score %u",
        hand_count(game_state->dealer_cards, game_state->dealer_card_count));

    canvas_set_font(canvas, FontSecondary);
    canvas_draw_str_aligned(canvas, 122, 15, AlignRight, AlignCenter, dealer_score);

    canvas_draw_line(canvas, 3, 29, 124, 29);

    draw_label(canvas, 4, 33, "YOU");

    if(game_state->player_card_count > 0) {
        draw_compact_cards(
            canvas,
            game_state->player_cards,
            game_state->player_card_count,
            47,
            32);
    }

    char player_score[18];
    snprintf(
        player_score,
        sizeof(player_score),
        "Score %u",
        hand_count(game_state->player_cards, game_state->player_card_count));

    canvas_set_font(canvas, FontSecondary);
    canvas_draw_str_aligned(canvas, 122, 42, AlignRight, AlignCenter, player_score);
}

