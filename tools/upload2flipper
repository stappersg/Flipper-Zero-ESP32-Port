async def cmd_scan(args):
    ble = FlipperBLE()
    timeout = getattr(args, "timeout", 5.0) or 5.0
    all_devices = getattr(args, "all", False)
    devs = await ble.scan(timeout, all_devices=all_devices)

    if not devs:
        print("\nNo BLE devices found.")
        print("Tips:")
        print("  - Bluetooth must be ON on your Flipper (Settings -> Bluetooth)")
        print("  - Flipper should be on the home screen")
        print("  - On macOS: Terminal needs Bluetooth permission")
        return

    print(f"\nFound {len(devs)} device(s):")
    for i, d in enumerate(devs):
        rssi = getattr(d, "rssi", "?")
        print(f"  [{i}] {d.name:20s}  {d.address}  RSSI: {rssi}")

    if len(devs) == 1:
        save_config({"address": devs[0].address, "name": devs[0].name})
        print(f"\nSaved '{devs[0].name}' as default device.")
    else:
        # Let user pick a device
        try:
            choice = input(f"\nSelect device [0-{len(devs)-1}] (Enter to skip): ").strip()
            if choice.isdigit():
                idx = int(choice)
                if 0 <= idx < len(devs):
                    d = devs[idx]
                    save_config({"address": d.address, "name": d.name})
                    print(f"Saved '{d.name}' ({d.address}) as default device.")
                else:
                    print("Invalid selection.")
        except (EOFError, KeyboardInterrupt):
            print()


async def cmd_pair(args):
    addr = await resolve_address(args)
    ble = FlipperBLE()
    await ble.pair(addr)
    save_config({"address": addr, "name": "Flipper"})
    print(f"Device saved. Future commands will auto-connect.")


async def cmd_upload(args):
    local_file = args.local_file
    remote_path = normalize_path(args.remote_path)

    if not os.path.isfile(local_file):
        print(f"Error: File not found: {local_file}")
        sys.exit(1)

    with open(local_file, "rb") as f:
        data = f.read()

    print(f"File: {local_file} ({fmt_size(len(data))})")
    print(f"  -> {remote_path}")

    addr = await resolve_address(args)
    ble = FlipperBLE()

    try:
        await ble.connect(addr)
        rpc = FlipperRPC(ble)

        if await rpc.ping():
            print("RPC session active")

        # Create parent directories if needed (recursive)
        parent = os.path.dirname(remote_path)
        if parent and parent not in ("/ext", "/int"):
            await rpc.storage_mkdir_p(parent)

        # Upload
        print("Uploading...")
        t0 = time.time()
        await rpc.storage_write(remote_path, data, progress_cb=progress_bar)
        dt = time.time() - t0

        speed = len(data) / dt if dt > 0 else 0
        print(f"Done! {fmt_size(len(data))} in {dt:.1f}s ({speed:.0f} B/s)")
    finally:
        await ble.disconnect()


async def cmd_ls(args):
    path = normalize_path(getattr(args, "path", None) or "/ext")
    addr = await resolve_address(args)
    ble = FlipperBLE()

    try:
        await ble.connect(addr)
        rpc = FlipperRPC(ble)

        print(f"\n{path}/")
        files = await rpc.storage_list(path)

        if not files:
            print("  (empty)")
            return

        files.sort(key=lambda f: (0 if f["type"] == "DIR" else 1, f["name"]))

        for f in files:
            if f["type"] == "DIR":
                print(f"  [DIR]  {f['name']}/")
            else:
                print(f"  [FILE] {f['name']:30s}  {fmt_size(f['size'])}")
    finally:
        await ble.disconnect()


async def cmd_info(args):
    addr = await resolve_address(args)
    ble = FlipperBLE()

    try:
        await ble.connect(addr)
        rpc = FlipperRPC(ble)

        info = await rpc.device_info()

        print("\nDevice:")
        keys = [
            "hardware.name", "hardware.model",
            "firmware.version", "firmware.build.date",
            "firmware.target", "radio.stack.type",
        ]
        for k in keys:
            if k in info:
                print(f"  {k}: {info[k]}")

        # Print all other keys not in the important list
        other = {k: v for k, v in info.items() if k not in keys}
        if other:
            print("\n  All properties:")
            for k in sorted(other):
                print(f"    {k}: {other[k]}")

        try:
            total, free = await rpc.storage_info("/ext")
            if total:
                used = total - free
                pct = used / total * 100
                print(f"\nSD Card:")
                print(f"  Total: {fmt_size(total)}")
                print(f"  Free:  {fmt_size(free)}")
                print(f"  Used:  {fmt_size(used)} ({pct:.0f}%)")
        except Exception:
            print("\nSD Card: not available")
    finally:
        await ble.disconnect()


