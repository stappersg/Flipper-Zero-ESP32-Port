#!/usr/bin/env python3
"""
upload2flipper - Upload files to Flipper Zero via Bluetooth LE

Uses the Flipper Zero protobuf RPC protocol over BLE serial.
BLE UUIDs and protocol from the firmware source (assets/protobuf/).

Usage:
    upload2flipper scan                          # Find Flipper devices
    upload2flipper pair                          # Pair with Flipper
    upload2flipper upload <local> <remote>       # Upload file
    upload2flipper <local> <remote>              # Upload (shorthand)
    upload2flipper download <remote> [local]     # Download file
    upload2flipper fap <file.fap> [category]     # Upload FAP to /ext/apps/<cat>
    upload2flipper ls [path]                     # List directory
    upload2flipper info                          # Device & storage info
    upload2flipper mkdir <path>                  # Create directory
    upload2flipper delete <path> [-r]            # Delete file or directory
    upload2flipper test-fs [-s SIZE]              # Upload/download round-trip test
    upload2flipper log [LEVEL]                   # Stream debug logs via BLE RPC (debug/info/warn/error/trace)

Options:
    -a, --address ADDR    BLE address (skip auto-scan)

Paths:
    /sdcard/... is automatically mapped to /ext/...
    Paths without /ext or /int prefix default to /ext/

Requirements:
    pip install bleak
"""

import asyncio
import argparse
import struct
import sys
import os
import time
import json
import logging

log = logging.getLogger("upload2flipper")

try:
    from bleak import BleakClient, BleakScanner
except ImportError:
    print("Missing dependency. Install with:")
    print("  pip install bleak")
    sys.exit(1)


# ── BLE UUIDs (from firmware: targets/f7/ble_glue/services/serial_service_uuid.inc) ──

SERVICE   = "8fe5b3d5-2e7f-4a98-2a48-7acc60fe0000"
CHAR_TX   = "19ed82ae-ed21-4c9d-4145-228e61fe0000"   # Flipper -> Client (notify)
CHAR_RX   = "19ed82ae-ed21-4c9d-4145-228e62fe0000"   # Client -> Flipper (write)
CHAR_FLOW = "19ed82ae-ed21-4c9d-4145-228e63fe0000"   # Flow control (notify/read)
CHAR_RPC  = "19ed82ae-ed21-4c9d-4145-228e64fe0000"   # RPC status

# Max file data bytes per protobuf chunk (from assets/protobuf/storage.options)
CHUNK_SIZE = 512

CONFIG_PATH = os.path.expanduser("~/.config/upload2flipper/device.json")


# ════════════════════════════════════════════════════════════
# Minimal Protobuf Wire Format (no protobuf dependency needed)
# ════════════════════════════════════════════════════════════

def _ve(v):
    """Encode varint."""
    out = bytearray()
    while v > 0x7F:
        out.append((v & 0x7F) | 0x80)
        v >>= 7
    out.append(v & 0x7F)
    return bytes(out)


def _vd(data, pos=0):
    """Decode varint -> (value, new_pos)."""
    r, s = 0, 0
    while pos < len(data):
        b = data[pos]
        r |= (b & 0x7F) << s
        pos += 1
        if not (b & 0x80):
            return r, pos
        s += 7
    raise ValueError("incomplete varint")


def _fv(fn, v):
    """Encode varint field."""
    return _ve((fn << 3) | 0) + _ve(v)


def _fb(fn, d):
    """Encode length-delimited field (bytes/string/embedded message)."""
    return _ve((fn << 3) | 2) + _ve(len(d)) + d


def _fs(fn, s):
    """Encode string field."""
    return _fb(fn, s.encode("utf-8"))


def _dm(data):
    """Decode protobuf message -> {field_number: [values]}."""
    fields = {}
    pos = 0
    while pos < len(data):
        tag, pos = _vd(data, pos)
        fn, wt = tag >> 3, tag & 7
        if wt == 0:
            val, pos = _vd(data, pos)
        elif wt == 2:
            ln, pos = _vd(data, pos)
            val = data[pos:pos + ln]
            pos += ln
        elif wt == 5:
            val = struct.unpack_from("<I", data, pos)[0]
            pos += 4
        elif wt == 1:
            val = struct.unpack_from("<Q", data, pos)[0]
            pos += 8
        else:
            break
        fields.setdefault(fn, []).append(val)
    return fields


# ════════════════════════════════════════════════════════════
# RPC Message Builders (field numbers from assets/protobuf/)
# ════════════════════════════════════════════════════════════

# Main message field numbers (flipper.proto)
F_CMD_ID = 1
F_STATUS = 2
F_HAS_NEXT = 3
F_PING_REQ = 5
F_LIST_REQ = 7
F_LIST_RESP = 8
F_READ_REQ = 9
F_READ_RESP = 10
F_WRITE_REQ = 11
F_DELETE_REQ = 12
F_MKDIR_REQ = 13
F_INFO_REQ = 28
F_INFO_RESP = 29
F_DEVINFO_REQ = 32
F_DEVINFO_RESP = 33
F_LOG_START_REQ = 76
F_LOG_STOP_REQ = 77
F_LOG_FRAME = 78

STATUS_NAMES = {
    0: "OK", 1: "ERROR", 2: "ERROR_DECODE", 3: "NOT_IMPLEMENTED",
    4: "BUSY", 5: "STORAGE_NOT_READY", 6: "STORAGE_EXIST",
    7: "STORAGE_NOT_EXIST", 8: "STORAGE_INVALID_PARAM",
    9: "STORAGE_DENIED", 10: "STORAGE_INVALID_NAME",
    11: "STORAGE_INTERNAL", 12: "STORAGE_NOT_IMPL",
    13: "STORAGE_ALREADY_OPEN", 14: "CONTINUOUS_CMD_INTERRUPTED",
    15: "INVALID_PARAMETERS", 18: "STORAGE_DIR_NOT_EMPTY",
}


def _main(cmd_id, field_no, inner, has_next=False):
    """Build a Main RPC message."""
    m = _fv(F_CMD_ID, cmd_id)
    if has_next:
        m += _fv(F_HAS_NEXT, 1)
    m += _fb(field_no, inner)
    return m


def msg_ping(cid):
    return _main(cid, F_PING_REQ, _fb(1, b"\x00"))


def msg_devinfo(cid):
    return _main(cid, F_DEVINFO_REQ, b"")


def msg_list(cid, path):
    return _main(cid, F_LIST_REQ, _fs(1, path))


def msg_info(cid, path):
    return _main(cid, F_INFO_REQ, _fs(1, path))


def msg_mkdir(cid, path):
    return _main(cid, F_MKDIR_REQ, _fs(1, path))


def msg_read(cid, path):
    return _main(cid, F_READ_REQ, _fs(1, path))


def msg_delete(cid, path, recursive=False):
    inner = _fs(1, path)
    if recursive:
        inner += _fv(2, 1)
    return _main(cid, F_DELETE_REQ, inner)


def msg_write(cid, path, data=b"", has_next=False):
    """Build storage_write_request.

    Path must be included in every chunk (firmware validates it each time).
    Last chunk has has_next=False.
    """
    file_msg = _fb(4, data)            # File { data }
    wr = _fs(1, path)                  # WriteRequest.path
    wr += _fb(2, file_msg)             # WriteRequest.file
    return _main(cid, F_WRITE_REQ, wr, has_next=has_next)


def msg_log_start(cid, level=""):
    """Build StartLogStreamRequest."""
    inner = _fs(1, level) if level else b""
    return _main(cid, F_LOG_START_REQ, inner)


def msg_log_stop(cid):
    """Build StopLogStreamRequest."""
    return _main(cid, F_LOG_STOP_REQ, b"")


# ════════════════════════════════════════════════════════════
# Response Parsers
# ════════════════════════════════════════════════════════════

def parse_main(data):
    """Parse a Main response."""
    f = _dm(data)
    return {
        "cmd_id": f.get(F_CMD_ID, [0])[0],
        "status": f.get(F_STATUS, [0])[0],
        "has_next": bool(f.get(F_HAS_NEXT, [0])[0]),
        "content": {k: v for k, v in f.items() if k > 3},
    }


def parse_files(list_resp_data):
    """Parse StorageListResponse -> list of file dicts."""
    fields = _dm(list_resp_data)
    files = []
    for fd in fields.get(1, []):   # repeated File
        if isinstance(fd, (bytes, bytearray)):
            ff = _dm(fd)
            name = ff.get(2, [b""])[0]
            if isinstance(name, (bytes, bytearray)):
                name = name.decode("utf-8", errors="replace")
            files.append({
                "type": "DIR" if ff.get(1, [0])[0] == 1 else "FILE",
                "name": name,
                "size": ff.get(3, [0])[0],
            })
    return files


# ════════════════════════════════════════════════════════════
# BLE Transport
# ════════════════════════════════════════════════════════════

class FlipperBLE:
    """Low-level BLE serial transport for Flipper Zero RPC."""

    def __init__(self):
        self.client = None
        self._rxbuf = bytearray()
        self._rxq = asyncio.Queue()
        self._buf_free = 0
        self._flow_evt = asyncio.Event()

    # ── Scanning ──

    async def scan(self, timeout=5.0, all_devices=False):
        print(f"Scanning ({timeout}s)...")

        if not all_devices:
            # Try with service UUID filter first
            found = []
            try:
                devs = await BleakScanner.discover(
                    timeout=timeout, service_uuids=[SERVICE]
                )
                found = [d for d in devs if d.name]
            except Exception:
                pass

            # Fallback: scan all, filter by name
            if not found:
                devs = await BleakScanner.discover(timeout=timeout)
                found = [d for d in devs if d.name and "flipper" in d.name.lower()]
            return found
        else:
            # Show all BLE devices
            devs = await BleakScanner.discover(timeout=timeout)
            return [d for d in devs if d.name]

    # ── Callbacks ──

    def _on_data(self, _sender, data):
        log.debug(f"BLE RX: {len(data)} bytes")
        self._rxq.put_nowait(bytes(data))

    def _on_flow(self, _sender, data):
        if len(data) >= 4:
            old = self._buf_free
            self._buf_free = struct.unpack("<I", data[:4])[0]
            log.debug(f"Flow control: buf_free {old} -> {self._buf_free}")
            self._flow_evt.set()

    # ── Connection ──

    def _on_disconnect(self, client):
        log.warning(f"BLE DISCONNECTED (was connected to {client.address})")

    async def connect(self, addr):
        print(f"Connecting to {addr}...")
        self.client = BleakClient(addr, disconnected_callback=self._on_disconnect)
        await self.client.connect()
        print(f"Connected (MTU={self.client.mtu_size})")
        log.debug(f"BLE connected, MTU={self.client.mtu_size}")

        # Subscribe to data notifications (Flipper -> us)
        await self.client.start_notify(CHAR_TX, self._on_data)
        log.debug("Subscribed to TX notifications")

        # Subscribe to flow control
        await self.client.start_notify(CHAR_FLOW, self._on_flow)
        try:
            fc = await self.client.read_gatt_char(CHAR_FLOW)
            self._buf_free = struct.unpack("<I", fc[:4])[0]
            log.debug(f"Initial flow control buf_free={self._buf_free}")
        except Exception as e:
            self._buf_free = 1024
            log.debug(f"Flow control read failed ({e}), defaulting buf_free=1024")

        # Activate RPC session
        try:
            await self.client.write_gatt_char(
                CHAR_RPC, struct.pack("<I", 1), response=True
            )
            log.debug("RPC session activated via CHAR_RPC")
        except Exception as e:
            log.debug(f"RPC activation skipped ({e})")

        await asyncio.sleep(0.3)

    async def disconnect(self):
        if self.client and self.client.is_connected:
            log.debug("BLE disconnect: disconnecting...")
            try:
                await self.client.disconnect()
                log.debug("BLE disconnect: done")
            except Exception as e:
                log.debug(f"BLE disconnect: {e}")
        else:
            log.debug(f"BLE disconnect: already disconnected (client={self.client is not None}, connected={self.client.is_connected if self.client else 'N/A'})")

    async def pair(self, addr):
        """Pair/bond with Flipper Zero."""
        print(f"Pairing with {addr}...")
        self.client = BleakClient(addr)
        await self.client.connect()
        try:
            await self.client.pair()
            print("Paired successfully!")
        except NotImplementedError:
            print("macOS handles pairing automatically on first connection.")
            print("If prompted, confirm on your Flipper Zero.")
        except Exception as e:
            print(f"Pairing note: {e}")
            print("Connection established - should be paired now.")
        await self.client.disconnect()

    # ── Send / Receive ──

    async def send(self, msg_bytes):
        """Send a length-prefixed protobuf message over BLE serial."""
        frame = _ve(len(msg_bytes)) + msg_bytes
        chunk_size = min(self.client.mtu_size - 3, 512) if self.client else 128
        log.debug(f"BLE TX: frame={len(frame)}B, msg={len(msg_bytes)}B, ble_chunk={chunk_size}B")

        # Check connection before sending
        if not self.client.is_connected:
            log.error("BLE TX aborted: not connected!")
            raise RuntimeError("BLE connection lost before send")

        # Flow control: wait until Flipper has buffer space
        retries = 0
        while self._buf_free < len(frame) and retries < 100:
            log.debug(f"Flow control: waiting, buf_free={self._buf_free}, need={len(frame)}, retry={retries}")
            self._flow_evt.clear()
            try:
                await asyncio.wait_for(self._flow_evt.wait(), 0.5)
            except asyncio.TimeoutError:
                retries += 1
        if retries >= 100:
            log.warning(f"Flow control: gave up after {retries} retries, buf_free={self._buf_free}, need={len(frame)}")

        # Send in BLE-sized chunks (response=True to prevent RX overflow on device)
        ble_chunks = (len(frame) + chunk_size - 1) // chunk_size
        for idx, i in enumerate(range(0, len(frame), chunk_size)):
            chunk = frame[i:i + chunk_size]
            log.debug(f"BLE TX chunk {idx+1}/{ble_chunks}: {len(chunk)}B, connected={self.client.is_connected}")
            try:
                await self.client.write_gatt_char(
                    CHAR_RX, chunk, response=True
                )
            except Exception as e:
                log.error(f"BLE TX chunk {idx+1}/{ble_chunks} FAILED: {e}")
                raise

        self._buf_free = max(0, self._buf_free - len(frame))
        log.debug(f"BLE TX done, buf_free now={self._buf_free}")

    async def recv(self, timeout=10.0):
        """Receive one length-prefixed protobuf message."""
        deadline = time.time() + timeout
        log.debug(f"BLE recv: waiting (timeout={timeout}s, rxbuf={len(self._rxbuf)}B)")

        while True:
            # Try to extract a complete message from the buffer
            if self._rxbuf:
                try:
                    msg_len, hdr_size = _vd(bytes(self._rxbuf))
                    if len(self._rxbuf) >= hdr_size + msg_len:
                        msg = bytes(self._rxbuf[hdr_size:hdr_size + msg_len])
                        del self._rxbuf[:hdr_size + msg_len]
                        log.debug(f"BLE recv: got message {len(msg)}B (rxbuf remaining={len(self._rxbuf)}B)")
                        return msg
                    else:
                        log.debug(f"BLE recv: partial message, have {len(self._rxbuf)}B, need {hdr_size + msg_len}B")
                except ValueError:
                    pass

            remaining = deadline - time.time()
            if remaining <= 0:
                log.error(f"BLE recv: TIMEOUT after {timeout}s, rxbuf={len(self._rxbuf)}B, connected={self.client.is_connected if self.client else 'N/A'}")
                raise TimeoutError("No response from Flipper")

            try:
                chunk = await asyncio.wait_for(
                    self._rxq.get(), timeout=min(remaining, 2.0)
                )
                log.debug(f"BLE recv: got {len(chunk)}B from queue, rxbuf now={len(self._rxbuf) + len(chunk)}B")
                self._rxbuf.extend(chunk)
            except asyncio.TimeoutError:
                log.debug(f"BLE recv: queue timeout, {remaining:.1f}s remaining, connected={self.client.is_connected if self.client else 'N/A'}")
                continue


# ════════════════════════════════════════════════════════════
# RPC Client
# ════════════════════════════════════════════════════════════

class FlipperRPC:
    """High-level Flipper Zero RPC over BLE."""

    def __init__(self, ble: FlipperBLE):
        self.ble = ble
        self._cid = 0

    def _next_id(self):
        self._cid += 1
        return self._cid

    async def _call(self, msg, timeout=10.0):
        """Send message, collect all response parts (handling has_next)."""
        log.debug(f"RPC _call: sending {len(msg)}B, timeout={timeout}s")
        await self.ble.send(msg)
        resps = []
        while True:
            data = await self.ble.recv(timeout=timeout)
            r = parse_main(data)
            log.debug(f"RPC _call: response part {len(resps)+1}, status={r['status']}, has_next={r['has_next']}, cmd_id={r['cmd_id']}")
            resps.append(r)
            if not r["has_next"]:
                break
        return resps

    def _check(self, resps, op="Operation"):
        s = resps[-1]["status"]
        if s != 0:
            raise RuntimeError(f"{op}: {STATUS_NAMES.get(s, f'error {s}')}")

    async def ping(self):
        resps = await self._call(msg_ping(self._next_id()))
        return resps[0]["status"] == 0

    async def device_info(self):
        resps = await self._call(msg_devinfo(self._next_id()), timeout=15.0)
        info = {}
        for r in resps:
            for d in r["content"].get(F_DEVINFO_RESP, []):
                if isinstance(d, (bytes, bytearray)):
                    f = _dm(d)
                    k = f.get(1, [b""])[0]
                    v = f.get(2, [b""])[0]
                    if isinstance(k, bytes):
                        k = k.decode(errors="replace")
                    if isinstance(v, bytes):
                        v = v.decode(errors="replace")
                    if k:
                        info[k] = v
        return info

    async def storage_info(self, path="/ext"):
        resps = await self._call(msg_info(self._next_id(), path))
        self._check(resps, "storage_info")
        for r in resps:
            for d in r["content"].get(F_INFO_RESP, []):
                if isinstance(d, (bytes, bytearray)):
                    f = _dm(d)
                    return f.get(1, [0])[0], f.get(2, [0])[0]
        return 0, 0

    async def storage_list(self, path):
        resps = await self._call(msg_list(self._next_id(), path), timeout=15.0)
        self._check(resps, "ls")
        files = []
        for r in resps:
            for d in r["content"].get(F_LIST_RESP, []):
                if isinstance(d, (bytes, bytearray)):
                    files.extend(parse_files(d))
        return files

    async def storage_mkdir(self, path):
        resps = await self._call(msg_mkdir(self._next_id(), path))
        s = resps[-1]["status"]
        if s not in (0, 6):  # OK or ALREADY_EXISTS
            raise RuntimeError(f"mkdir: {STATUS_NAMES.get(s, f'error {s}')}")

    async def storage_mkdir_p(self, path):
        """Recursively create directories (like mkdir -p)."""
        parts = path.strip("/").split("/")
        for i in range(2, len(parts) + 1):  # Start at 2 to skip mount points (/ext, /int)
            p = "/" + "/".join(parts[:i])
            await self.storage_mkdir(p)
            await asyncio.sleep(0.05)

    async def storage_write(self, remote_path, data, progress_cb=None):
        """Write file to Flipper storage. Chunks data for BLE transfer."""
        cid = self._next_id()
        total = len(data)
        offset = 0
        chunk_num = 0
        total_chunks = (total + CHUNK_SIZE - 1) // CHUNK_SIZE if total > 0 else 1

        log.info(f"storage_write: path={remote_path}, size={total}B, chunks={total_chunks}, chunk_size={CHUNK_SIZE}B, cmd_id={cid}")

        if total == 0:
            # Empty file
            log.debug("storage_write: empty file")
            await self.ble.send(msg_write(cid, path=remote_path, data=b""))
        else:
            while offset < total:
                chunk = data[offset:offset + CHUNK_SIZE]
                is_first = (offset == 0)
                offset += len(chunk)
                is_last = (offset >= total)

                m = msg_write(
                    cid,
                    path=remote_path,
                    data=chunk,
                    has_next=not is_last,
                )
                chunk_num += 1
                log.debug(f"storage_write: chunk {chunk_num}/{total_chunks}, {len(chunk)}B, offset={offset}/{total}, has_next={not is_last}, connected={self.ble.client.is_connected}")

                try:
                    await self.ble.send(m)
                except Exception as e:
                    log.error(f"storage_write: SEND FAILED at chunk {chunk_num}/{total_chunks}, offset={offset}/{total}: {e}")
                    raise

                if progress_cb:
                    progress_cb(offset, total)

                # Small delay every 8 chunks to let device process
                if not is_last and chunk_num % 8 == 0:
                    log.debug(f"storage_write: processing delay 0.01s")
                    await asyncio.sleep(0.01)

        # Wait for write response
        log.info(f"storage_write: all {chunk_num} chunks sent, waiting for response...")
        resp_data = await self.ble.recv(timeout=30.0)
        resp = parse_main(resp_data)

        log.info(f"storage_write: response status={resp['status']} ({STATUS_NAMES.get(resp['status'], '?')}), has_next={resp['has_next']}")

        if resp["status"] != 0:
            raise RuntimeError(
                f"Write failed: {STATUS_NAMES.get(resp['status'], resp['status'])}"
            )

    async def storage_read(self, remote_path, progress_cb=None):
        """Read file from Flipper storage. Returns bytes."""
        resps = await self._call(
            msg_read(self._next_id(), remote_path), timeout=30.0
        )
        self._check(resps, "Read")

        data = bytearray()
        for r in resps:
            for d in r["content"].get(F_READ_RESP, []):
                if isinstance(d, (bytes, bytearray)):
                    f = _dm(d)
                    # File message field 1 -> nested File, data is field 4
                    for file_msg in f.get(1, []):
                        if isinstance(file_msg, (bytes, bytearray)):
                            ff = _dm(file_msg)
                            for chunk in ff.get(4, []):
                                if isinstance(chunk, (bytes, bytearray)):
                                    data.extend(chunk)
                    # data might also be directly in field 4
                    for chunk in f.get(4, []):
                        if isinstance(chunk, (bytes, bytearray)):
                            data.extend(chunk)
            if progress_cb and data:
                progress_cb(len(data), 0)

        return bytes(data)

    async def storage_delete(self, remote_path, recursive=False):
        """Delete a file or directory on Flipper storage."""
        resps = await self._call(
            msg_delete(self._next_id(), remote_path, recursive=recursive)
        )
        self._check(resps, "Delete")


