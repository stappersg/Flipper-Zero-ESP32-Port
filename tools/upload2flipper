COMMANDS = ["scan", "pair", "upload", "download", "fap", "ls", "info", "mkdir", "delete", "rm", "test-fs", "log"]


def main():
    # Support shorthand: upload2flipper file.txt /ext/file.txt (no subcommand)
    if (
        len(sys.argv) >= 3
        and sys.argv[1] not in COMMANDS
        and not sys.argv[1].startswith("-")
    ):
        sys.argv.insert(1, "upload")

    parser = argparse.ArgumentParser(
        prog="upload2flipper",
        description="Flipper Zero BLE file transfer tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""Examples:
  upload2flipper scan
  upload2flipper pair
  upload2flipper my_signal.sub /ext/subghz/my_signal.sub
  upload2flipper upload firmware.bin /ext/update/firmware.bin
  upload2flipper download /ext/subghz/signal.sub
  upload2flipper download /ext/subghz/signal.sub local_copy.sub
  upload2flipper fap myApp.fap                  # -> /ext/apps/Tools/myApp.fap
  upload2flipper fap myApp.fap GPIO             # -> /ext/apps/GPIO/myApp.fap
  upload2flipper ls /ext/subghz
  upload2flipper info""",
    )
    parser.add_argument("-a", "--address", help="BLE address (skip auto-scan)")
    parser.add_argument("-d", "--debug", action="store_true", help="Enable debug logging")

    sub = parser.add_subparsers(dest="command")

    p_scan = sub.add_parser("scan", help="Scan for Flipper Zero devices")
    p_scan.add_argument(
        "-t", "--timeout", type=float, default=5.0, help="Scan timeout (default: 5s)"
    )
    p_scan.add_argument(
        "-A", "--all", action="store_true",
        help="Show all BLE devices (not just Flipper)",
    )

    sub.add_parser("pair", help="Pair with Flipper Zero via BLE")

    p_up = sub.add_parser("upload", help="Upload file to Flipper")
    p_up.add_argument("local_file", help="Local file path")
    p_up.add_argument("remote_path", help="Remote path (e.g. /ext/subghz/file.sub)")

    p_dl = sub.add_parser("download", help="Download file from Flipper")
    p_dl.add_argument("remote_path", help="Remote path (e.g. /ext/subghz/file.sub)")
    p_dl.add_argument("local_file", nargs="?", default=None, help="Local file path (default: filename from remote)")

    p_fap = sub.add_parser("fap", help="Upload FAP app to Flipper")
    p_fap.add_argument("fap_file", help="Local .fap file")
    p_fap.add_argument(
        "category", nargs="?", default="Tools",
        help="App category folder (default: Tools)",
    )

    p_ls = sub.add_parser("ls", help="List directory on Flipper")
    p_ls.add_argument("path", nargs="?", default="/ext", help="Path (default: /ext)")

    sub.add_parser("info", help="Show device info and storage")

    p_mk = sub.add_parser("mkdir", help="Create directory on Flipper")
    p_mk.add_argument("path", help="Directory path")

    p_del = sub.add_parser("delete", aliases=["rm"], help="Delete file or directory on Flipper")
    p_del.add_argument("path", help="File or directory path")
    p_del.add_argument("-r", "--recursive", action="store_true", help="Delete directory recursively")

    p_test = sub.add_parser("test-fs", help="Upload/download test to validate BLE transfer")
    p_test.add_argument(
        "-s", "--size", type=int, default=512,
        help="Test file size in bytes (default: 512)",
    )

    p_log = sub.add_parser("log", help="Stream Flipper debug logs via BLE RPC")
    p_log.add_argument(
        "level", nargs="?", default="debug",
        help="Log level: debug, info, warn, error, trace (default: debug)",
    )

    args = parser.parse_args()

    # Setup logging
    if args.debug:
        logging.basicConfig(
            level=logging.DEBUG,
            format="%(asctime)s.%(msecs)03d [%(levelname)s] %(message)s",
            datefmt="%H:%M:%S",
        )
    else:
        logging.basicConfig(
            level=logging.WARNING,
            format="[%(levelname)s] %(message)s",
        )

    if not args.command:
        parser.print_help()
        sys.exit(1)

    cmd_map = {
        "scan": cmd_scan,
        "pair": cmd_pair,
        "upload": cmd_upload,
        "download": cmd_download,
        "fap": cmd_fap,
        "ls": cmd_ls,
        "info": cmd_info,
        "mkdir": cmd_mkdir,
        "delete": cmd_delete,
        "rm": cmd_delete,
        "test-fs": cmd_test_fs,
        "log": cmd_log,
    }

    try:
        asyncio.run(cmd_map[args.command](args))
    except KeyboardInterrupt:
        print("\nAborted.")
        sys.exit(130)
    except Exception as e:
        print(f"\nError: {e}")
        if args.debug:
            import traceback
            traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()
