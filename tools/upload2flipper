async def cmd_test_fs(args):
    """Upload a test file, download it back, and validate integrity."""
    import hashlib
    import random

    size = getattr(args, "size", 512) or 512
    remote_path = "/ext/.upload2flipper_test"

    # Generate random test data
    test_data = bytes(random.getrandbits(8) for _ in range(size))
    test_hash = hashlib.md5(test_data).hexdigest()

    print(f"Test file: {fmt_size(size)} of random data")
    print(f"  MD5: {test_hash}")
    print(f"  Remote: {remote_path}")

    addr = await resolve_address(args)
    ble = FlipperBLE()

    try:
        await ble.connect(addr)
        rpc = FlipperRPC(ble)

        if await rpc.ping():
            print("RPC session active")

        # Upload
        print("\n[1/3] Uploading...")
        t0 = time.time()
        await rpc.storage_write(remote_path, test_data, progress_cb=progress_bar)
        dt_up = time.time() - t0
        speed_up = size / dt_up if dt_up > 0 else 0
        print(f"  Upload: {dt_up:.1f}s ({speed_up:.0f} B/s)")

        # Download
        print("\n[2/3] Downloading...")
        t0 = time.time()
        dl_data = await rpc.storage_read(remote_path)
        dt_dl = time.time() - t0
        dl_hash = hashlib.md5(dl_data).hexdigest()
        speed_dl = len(dl_data) / dt_dl if dt_dl > 0 else 0
        print(f"  Downloaded: {fmt_size(len(dl_data))} in {dt_dl:.1f}s ({speed_dl:.0f} B/s)")
        print(f"  MD5: {dl_hash}")

        # Validate
        print("\n[3/3] Validating...")
        ok = True

        if len(dl_data) != size:
            print(f"  FAIL: Size mismatch! Sent {size}, got {len(dl_data)}")
            ok = False

        if dl_hash != test_hash:
            print(f"  FAIL: Hash mismatch!")
            print(f"    Sent:     {test_hash}")
            print(f"    Received: {dl_hash}")
            # Find first differing byte
            for i in range(min(len(test_data), len(dl_data))):
                if test_data[i] != dl_data[i]:
                    print(f"    First diff at byte {i}: sent 0x{test_data[i]:02x}, got 0x{dl_data[i]:02x}")
                    break
            ok = False

        if ok:
            print(f"  OK! Round-trip verified ({fmt_size(size)})")

        # Cleanup
        try:
            await rpc.storage_delete(remote_path)
            print(f"\nCleaned up {remote_path}")
        except Exception as e:
            print(f"\nWarning: cleanup failed: {e}")

        if not ok:
            sys.exit(1)

    finally:
        await ble.disconnect()


async def cmd_log(args):
    """Stream Flipper debug logs via BLE RPC."""
    level = args.level or ""
    addr = await resolve_address(args)
    ble = FlipperBLE()

    try:
        await ble.connect(addr)
        rpc = FlipperRPC(ble)

        if await rpc.ping():
            print("RPC session active")

        # Send StartLogStreamRequest
        cid = rpc._next_id()
        await ble.send(msg_log_start(cid, level))
        resp_data = await ble.recv(timeout=5.0)
        resp = parse_main(resp_data)
        if resp["status"] != 0:
            raise RuntimeError(
                f"StartLogStream: {STATUS_NAMES.get(resp['status'], resp['status'])}"
            )

        print(f"Streaming logs (level: {level or 'default'})... Press Ctrl+C to stop.\n")

        # Receive log frames
        while True:
            try:
                data = await ble.recv(timeout=2.0)
            except TimeoutError:
                continue
            msg = parse_main(data)
            for frame_data in msg["content"].get(F_LOG_FRAME, []):
                if isinstance(frame_data, (bytes, bytearray)):
                    # Parse LogStreamFrame: field 1 = bytes data
                    fields = _dm(frame_data)
                    for chunk in fields.get(1, []):
                        if isinstance(chunk, (bytes, bytearray)):
                            sys.stdout.write(chunk.decode("utf-8", errors="replace"))
                            sys.stdout.flush()

    except KeyboardInterrupt:
        print("\n\nStopping log...")
        try:
            stop_cid = rpc._next_id()
            await ble.send(msg_log_stop(stop_cid))
            resp_data = await ble.recv(timeout=3.0)
        except Exception:
            pass
    finally:
        await ble.disconnect()


