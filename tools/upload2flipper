def fmt_size(n):
    if n < 1024:
        return f"{n} B"
    if n < 1024 * 1024:
        return f"{n / 1024:.1f} KB"
    return f"{n / (1024 * 1024):.1f} MB"


def progress_bar(cur, total, width=40):
    pct = cur / total if total else 1.0
    filled = int(width * pct)
    bar = "#" * filled + "-" * (width - filled)
    sys.stdout.write(f"\r  [{bar}] {pct * 100:.0f}% {fmt_size(cur)}/{fmt_size(total)}")
    sys.stdout.flush()
    if cur >= total:
        print()


def normalize_path(path):
    """Map /sdcard/ -> /ext/, ensure valid Flipper path."""
    if path.startswith("/sdcard"):
        path = "/ext" + path[7:]
    if not (path.startswith("/ext") or path.startswith("/int")):
        path = "/ext/" + path.lstrip("/")
    return path


async def resolve_address(args):
    """Get Flipper BLE address from args, config, or auto-scan."""
    if getattr(args, "address", None):
        return args.address

    cfg = load_config()
    if cfg.get("address"):
        name = cfg.get("name", "Flipper")
        print(f"Using saved device: {name} ({cfg['address']})")
        return cfg["address"]

    # Auto-scan
    ble = FlipperBLE()
    devs = await ble.scan()

    if not devs:
        print("No Flipper Zero found.")
        print("  - Is Bluetooth ON on your Flipper?")
        print("  - Is Flipper on the home screen?")
        print("  - Does Terminal have Bluetooth permission? (macOS)")
        sys.exit(1)

    if len(devs) == 1:
        d = devs[0]
        print(f"Found: {d.name} ({d.address})")
        save_config({"address": d.address, "name": d.name})
        return d.address

    print("Multiple Flippers found:")
    for i, d in enumerate(devs):
        rssi = getattr(d, "rssi", "?")
        print(f"  [{i}] {d.name:20s}  {d.address}  RSSI: {rssi}")

    try:
        choice = input(f"\nSelect device [0-{len(devs)-1}]: ").strip()
        if choice.isdigit():
            idx = int(choice)
            if 0 <= idx < len(devs):
                d = devs[idx]
                save_config({"address": d.address, "name": d.name})
                return d.address
        print("Invalid selection.")
    except (EOFError, KeyboardInterrupt):
        print()
    sys.exit(1)


