App(
    appid="nfc",
    name="NFC",
    apptype=FlipperAppType.MENUEXTERNAL,
    targets=["f7", "f32"],
    entry_point="nfc_app",
    icon="A_NFC_14",
    stack_size=5 * 1024,
    order=30,
    resources="resources",
    sources=["*.c*", "!plugins", "!nfc_cli.c", "!cli", "!api"],
    fap_libs=["assets", "mbedtls"],
    fap_icon="icon.png",
    fap_category="NFC",
)

# Protocol support plugins

App(
    appid="nfc_iso14443_3a",
    targets=["f7", "f32"],
    apptype=FlipperAppType.PLUGIN,
    entry_point="nfc_iso14443_3a_ep",
    requires=["nfc"],
    sources=[
